# ============================================================
# .env.example — Copier en .env et renseigner les valeurs
# Ne jamais committer le fichier .env dans le dépôt
# ============================================================

# --- Windows — Encodage console ---
# Force UTF-8 pour tous les I/O texte Python (stdout, stderr, fichiers).
# IMPORTANT : doit être définie dans l'environnement SYSTÈME avant le démarrage
# de Python pour corriger l'affichage console (trop tardif si chargée via .env).
# Ajouter dans le profil PowerShell ($PROFILE) :
#   $env:PYTHONUTF8 = "1"
# Ou en variable d'environnement utilisateur Windows (Paramètres → Variables d'environnement).
PYTHONUTF8=1

# --- Git ---
# Chemin vers l'exécutable git (optionnel).
# À définir UNIQUEMENT si git n'est pas dans le PATH système (cas Windows
# avec une installation non standard ou portable de Git for Windows).
# Si cette variable est définie, GitPython l'utilise directement et la
# détection automatique via PATH est court-circuitée.
# Exemple Windows : GIT_PYTHON_GIT_EXECUTABLE=C:\Program Files\Git\bin\git.exe
# GIT_PYTHON_GIT_EXECUTABLE=

# --- Jira ---
# URL de l'instance Jira (ex. https://monorg.atlassian.net)
JIRA_URL=https://your-org.atlassian.net
# Token d'API personnel Jira (Atlassian Account Settings → Security)
JIRA_TOKEN=your_jira_api_token

# --- Confluence ---
# URL de l'instance Confluence (souvent identique à Jira pour Cloud)
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
# Token d'API personnel Confluence (même compte que Jira)
CONFLUENCE_TOKEN=your_confluence_api_token

# --- Neo4j ---
# URI du serveur Neo4j (bolt ou neo4j+s)
NEO4J_URI=bolt://localhost:7687
# Utilisateur Neo4j
NEO4J_USER=neo4j
# Mot de passe Neo4j
NEO4J_PASSWORD=changeme

# --- LLM (endpoint OpenAI-compatible) — OPTIONNEL ---
#
# Par défaut, AUCUN LLM réseau n'est requis : le flux conversationnel
# (kb extract + kb ingest-extraction, kb search — voir skills kb-ingest et
# kb-ask) fonctionne sans rien configurer ici. C'est l'agent choisi dans
# Copilot Chat qui fait le travail d'extraction/rédaction, directement dans
# la conversation VS Code — aucun serveur, aucun port ouvert.
#
# Configurer OLLAMA_BASE_URL/OLLAMA_MODEL seulement si vous voulez le
# pipeline automatique en une commande (kb ingest / kb ask, sans passer par
# l'agent) :
#
# Option A — Ollama local (si disponible)
# Prérequis : ollama serve + ollama pull mistral:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=mistral:7b
# LLM_API_KEY=          # laisser vide pour Ollama (pas d'authentification)

# Option B — Pont Copilot (option avancée, DÉCONSEILLÉE par défaut : ouvre
# un serveur HTTP local sur le port 4141 — préférer le flux conversationnel
# ci-dessus si un port local ouvert n'est pas souhaitable)
# GitHub Models (l'ancienne alternative basée sur un token models:read) a été
# retiré par GitHub le 30/07/2026 — ne plus l'utiliser, l'endpoint ne répond
# plus. À la place : l'extension VS Code copilot-bridge/ (incluse dans ce
# dépôt) expose GitHub Copilot Chat comme serveur local OpenAI-compatible,
# via l'API publique vscode.lm — voir .github/skills/kb-copilot-bridge/SKILL.md
# Prérequis : abonnement GitHub Copilot actif + Node.js 20+ + VS Code ouvert
# avec l'extension démarrée (le pont n'est PAS un service headless).
# Pour utiliser cette option, décommenter les 3 lignes suivantes
#   et commenter les 2 lignes Option A ci-dessus :
# OLLAMA_BASE_URL=http://127.0.0.1:4141/v1
# OLLAMA_MODEL=gpt-4o
# LLM_API_KEY=

# --- Embeddings & reranking (sentence-transformers) ---
# Modèle d'embeddings (BGE-M3 recommandé)
EMBEDDING_MODEL=BAAI/bge-m3
# Modèle de reranking (BGE-reranker-v2-m3 recommandé)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Cache HuggingFace (sentence-transformers / transformers) ---
# Répertoire de cache pour les modèles HuggingFace téléchargés au premier lancement.
# Par défaut : ~/.cache/huggingface/ (Linux/macOS) ou C:\Users\<user>\.cache\huggingface\ (Windows).
# IMPORTANT Windows : si votre nom d'utilisateur contient des espaces, définir
# ce chemin vers un répertoire sans espaces pour éviter des erreurs lors du
# chargement des modèles.
# Exemple Windows : HF_HOME=C:\kb-cache\huggingface
# bge-m3 (~2.3 Go) et bge-reranker-v2-m3 (~2.3 Go) sont téléchargés ici.
# HF_HOME=
